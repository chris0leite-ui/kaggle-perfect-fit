# Data — keep placeholders, ignore content
data/*
!data/.gitkeep

# Submissions — keep placeholder, ignore CSVs except committed final submissions
submissions/*
!submissions/.gitkeep
!submissions/submission_*.csv

# Common data formats
*.csv
*.zip
*.parquet
*.feather
*.h5

# Exception: final Kaggle submission CSVs are committed for easy download
!submissions/submission_*.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env

# Jupyter
.ipynb_checkpoints/

# Testing
.pytest_cache/

# Local exploration (not committed)
explore.py
